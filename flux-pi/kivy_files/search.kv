<SearchScreen>:
    BoxLayout:
        orientation: 'vertical'

        # Title Bar
        Label:
            id: title
            text: "Search"
            font_size: '24sp'
            bold: True
            color: (0, 1, 0, 1)  # Green text
            size_hint_y: None
            height: '50dp'
            canvas.before:
                Color:
                    rgba: (0, 0, 0, 1)  # Black background
                Rectangle:
                    pos: self.pos
                    size: self.size

        # Search Input
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            TextInput:
                id: search_input
                hint_text: "Search for songs, artists, albums..."
                foreground_color: (0, 1, 0, 1)
                background_color: (0, 0, 0, 1)
                multiline: False
                on_text_validate: root.search_music()
            Button:
                text: "Search"
                background_color: (0, 1, 0, 1)
                on_release: root.search_music()

        # Search Results
        ScrollView:
            GridLayout:
                id: search_results
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                row_default_height: '50dp'
                row_force_default: True
                spacing: '5dp'
                padding: '10dp'

<SearchResultButton>:
    Button:
        text: root.text
        size_hint_y: None
        height: '50dp'
        background_color: (0, 0, 0, 1)  # Black background
        color: (0, 1, 0, 1)  # Green text
        on_release: print(f"Selected: {self.text}")
