<PlaylistsScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # Title Bar
        Label:
            id: title
            text: "Playlists"
            font_size: '24sp'
            bold: True
            color: (0, 1, 0, 1)  # Green text
            size_hint_y: None
            height: '50dp'
            canvas.before:
                Color:
                    rgba: (0, 0, 0, 1)  # Black background
                Rectangle:
                    pos: self.pos
                    size: self.size
        
        # Scrollable List of Playlists
        ScrollView:
            GridLayout:
                id: playlists_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                row_default_height: '50dp'
                row_force_default: True
                spacing: '5dp'
                padding: '10dp'
