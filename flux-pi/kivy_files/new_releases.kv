<NewReleasesScreen>:
    name: "new_releases"

    BoxLayout:
        orientation: "vertical"
        canvas.before:
            Color:
                rgba: 0, 0, 0, 1  # Black background
            Rectangle:
                pos: self.pos
                size: self.size
        
        # Title Bar
        Label:
            id: title_bar
            text: "New Releases"
            size_hint_y: None
            height: dp(50)
            bold: True
            font_size: "24sp"
            color: 0, 1, 0, 1  # Green text
            halign: "center"

        ScrollView:
            do_scroll_x: False
            GridLayout:
                id: new_releases_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(5)
                padding: dp(10)

                # Example new release (will be dynamically populated in the Python file)
                Button:
                    text: "Song Name - Artist Name"
                    size_hint_y: None
                    height: dp(50)
                    color: 0, 1, 0, 1  # Green text
                    background_color: 0, 0, 0, 0  # Transparent background
                    on_release: app.play_new_release("Song Name", "Artist Name")

                    canvas.before:
                        Color:
                            rgba: (0, 1, 0, 0.5) if self.state == "down" else (0, 0, 0, 0)
                        Rectangle:
                            pos: self.pos
                            size: self.size
